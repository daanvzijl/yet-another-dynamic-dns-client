amends "package://github.com/jdx/hk/releases/download/v1.36.0/hk@1.36.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.36.0/hk@1.36.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    ["editorconfig_checker"] = Builtins.editorconfig_checker
    ["prettier"] = Builtins.prettier
    ["go_fmt"] = Builtins.go_fmt
    ["go_fumpt"] = Builtins.go_fumpt
    ["go_lines"] = Builtins.go_lines
    ["go_vet"] = (Builtins.go_vet) {
        check = "go vet ./..."
    }
    ["gomod_tidy"] = Builtins.gomod_tidy
    ["go_sec"] = (Builtins.go_sec) {
        check = "gosec ./..."
        glob = "**/**.go"
    }
    ["staticcheck"] {
        glob = "**/**.go"
        check = "staticcheck ./..."
    }
    ["govulncheck"] {
        glob = "**/**.go"
        check = "govulncheck ./..."
    }
    ["go_test_race"] {
        glob = "**/**.go"
        check = "go test -race ./..."
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = linters
    }
    ["fix"] {
        fix = true
        steps = linters
    }
    ["check"] {
        steps = linters
    }
}
